{
	admin off
	auto_https off
}

:{$PORT} {
	encode gzip

	# Proxy /api/* to the FastAPI backend (which also mounts at /api/v1/*).
	# API_PRIVATE_HOST must be set to servicename.railway.internal:PORT.
	# Fallback keeps Caddy alive if the var is missing — UI loads, API calls fail gracefully.
	handle /api/* {
		reverse_proxy http://{$API_PRIVATE_HOST:localhost:8000} {
			header_up Host {$API_PRIVATE_HOST:localhost:8000}
		}
	}

	# SPA — serve built assets, fall back to index.html for client-side routes.
	handle {
		root * /app/packages/web/dist
		file_server
		try_files {path} /index.html
	}
}
