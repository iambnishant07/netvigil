{
	admin off
	auto_https off
}

:{$PORT} {
	encode gzip

	# Proxy all /api/* requests to the FastAPI backend via Railway private
	# networking (bypasses CDN which drops service-to-service POST requests).
	handle /api/* {
		reverse_proxy http://netvigil-api.railway.internal:8080 {
			header_up Host netvigil-api.railway.internal
		}
	}

	# SPA — serve built assets, fall back to index.html for client-side routes.
	handle {
		root * /app/packages/web/dist
		file_server
		try_files {path} /index.html
	}
}
