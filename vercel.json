{
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @aankhanet/web build:prod",
  "outputDirectory": "packages/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://aankhanet-api.up.railway.app/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
