{
  "buildCommand": "pnpm --filter @netvigil/web build:prod",
  "outputDirectory": "packages/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://netvigil-api.up.railway.app/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
