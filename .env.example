# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=netvigil
POSTGRES_USER=netvigil
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka (KRaft) ────────────────────────────────────────────────────────────
# Inside Docker use kafka:9094; from host use localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── InfluxDB 2.x ─────────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=netvigil
INFLUXDB_BUCKET=netflow
INFLUXDB_PASSWORD=changeme

# ── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generate with:  python scripts/gen_jwt_keys.py
# Newlines must be replaced with \n when stored as a single-line env var.
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Anthropic Claude API ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── SMTP (alert dispatcher) ──────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=changeme
ALERT_FROM_EMAIL=noreply@netvigil.example

# ── Twilio SMS ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+61400000000

# ── Expo push notifications ──────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=changeme
