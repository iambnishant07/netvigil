# Copy to .env and fill in values. Never commit .env.

# PostgreSQL connection
DATABASE_URL=postgresql://aankhanet:aankhanet@localhost:5432/aankhanet

# JWT — generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH=private.pem
JWT_PUBLIC_KEY_PATH=public.pem

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Anthropic Claude (LLM narrative generation)
ANTHROPIC_API_KEY=

# Google OAuth (enables Google sign-in)
GOOGLE_CLIENT_ID=

# IP Geolocation
# Option A — MaxMind GeoLite2 local database (recommended for production).
#   Download GeoLite2-City.mmdb from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
#   Requires a free MaxMind account. Place the file at the path below.
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
#
# Option B — ipinfo.io HTTPS API (fallback when GeoLite2 DB is absent).
#   Free tier: 50,000 req/month. Sign up at https://ipinfo.io/signup
#   Leave blank to use the unauthenticated tier (~1,000 req/day).
IPINFO_TOKEN=
