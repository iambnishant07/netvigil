# Copy to .env and fill in values. Never commit .env.

# API base URL — set to your Railway API service URL in production
VITE_API_URL=https://your-api.up.railway.app/api/v1

# Mapbox access token (optional — needed for threat map)
VITE_MAPBOX_TOKEN=

# Google OAuth web client ID (optional — enables Google sign-in on login page)
VITE_GOOGLE_CLIENT_ID=
