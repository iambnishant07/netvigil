{
  "name": "@netvigil/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@netvigil/shared-types": "workspace:*",
    "@react-navigation/native": "^6.0.0",
    "@react-navigation/native-stack": "^6.0.0",
    "@tanstack/react-query": "^5.0.0",
    "expo": "~52.0.0",
    "expo-local-authentication": "~14.0.0",
    "expo-notifications": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "~18.3.12",
    "jest": "^29.0.0",
    "jest-expo": "~52.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(?:\\.pnpm/)?(?:react-native|@react-native(?:-community)?|expo(?:-modules-core)?(?:nent)?|@expo(?:nent)?(?:/.*)?|@unimodules(?:/.*)?|unimodules|sentry-expo|native-base|@react-navigation(?:/.*)?|expo-status-bar|expo-local-authentication|expo-notifications|@testing-library/react-native))"
    ],
    "collectCoverageFrom": [
      "**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!**/node_modules/**",
      "!babel.config.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60,
        "functions": 60,
        "branches": 60,
        "statements": 60
      }
    }
  }
}
