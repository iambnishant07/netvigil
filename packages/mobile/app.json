{
  "expo": {
    "name": "NetVigil",
    "slug": "netvigil",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "netvigil",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "au.edu.vu.netvigil"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e293b"
      },
      "package": "au.edu.vu.netvigil",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-local-authentication",
      "expo-notifications",
      "expo-web-browser",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": "MAPBOX_SECRET_DOWNLOAD_TOKEN"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a81c625a-08ba-4f88-8b49-7d1630c242e9"
      }
    }
  }
}
