{
  "expo": {
    "name": "NetVigil",
    "slug": "netvigil",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "netvigil",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "au.edu.vu.netvigil"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "au.edu.vu.netvigil",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-local-authentication",
      "expo-notifications",
      "expo-web-browser",
      "@rnmapbox/maps"
    ],
    "extra": {
      "eas": {
        "projectId": "a81c625a-08ba-4f88-8b49-7d1630c242e9"
      }
    }
  }
}
